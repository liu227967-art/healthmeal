{
  "expo": {
    "name": "HealthMeal",
    "slug": "healthmeal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lilyproject.healthmeal",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "HealthMeal uses your camera to identify ingredients and log meals from photos.",
        "NSHealthShareUsageDescription": "HealthMeal reads your step count and activity data to calculate calories burned.",
        "NSHealthUpdateUsageDescription": "HealthMeal writes workout data to Apple Health.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.lilyproject.healthmeal",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "HealthMeal accesses your photos to log meals.",
          "cameraPermission": "HealthMeal uses your camera to identify ingredients and log meals."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7e5d97e6-c174-46a2-9c2d-fa01486686b6"
      }
    },
    "owner": "lilyawesome"
  }
}
